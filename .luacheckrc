-- Luacheck configuration for dota2bot (OpenHyperAI fork)
-- Generated initially by scripts; maintained by hand from here on.
-- Policy: only global-related warnings (1xx) are enforced. A name flagged as
-- "accessing undefined variable" is either a typo or a leaked local — fix it
-- or, if it is a real engine/Bot API global, add it to read_globals below.
std = "lua51"
max_line_length = false
-- enforce only: 11x/12x/13x (global access), plus syntax errors (always fatal)
only = { "1" }

exclude_files = {
    ".luarocks/**",
    "node_modules/**",
}

-- Globals the Dota 2 Bot API / VScript engine provides (read-only for us)
