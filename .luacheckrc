-- Lua 5.1 compatibility fields used deliberately (TSTL shims use
-- `unpack or table.unpack`; FretBots uses table.getn)
globals.table = { fields = { "getn", "unpack" } }

-- game/ runs in the server-side VScript VM (engine classes, precache hooks)
files["game/"] = {
    globals = {
        "CBaseEntity", "CDOTABaseAbility", "CDOTA_Ability_Lua", "CDOTA_BaseNPC",
        "CDOTA_BaseNPC_Hero", "CDOTA_PlayerResource", "HasBaseClass",
        "LinkLuaModifier", "LinkLuaModifier_Engine",
        "PrecacheUnitByNameAsync", "PrecacheUnitByNameAsync_Engine",
        "PrecacheUnitByNameSync", "PrecacheUnitByNameSync_Engine",
    },
    read_globals = { "DOTA_ModifyXP_Unspecified" },
}

-- Deliberate print() overrides (prefix/route to game console)
files["bots/FretBots/Debug.lua"] = { globals = { "print" } }
files["bots/FunLib/aba_global_overrides.lua"] = { globals = { "print" } }
